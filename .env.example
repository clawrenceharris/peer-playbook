# Required application configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
DATABASE_URL=postgresql://user:password@host:5432/database

# Recommended local app URL for auth redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional Supabase storage configuration
NEXT_PUBLIC_SUPABASE_AVATAR_BUCKET=avatars

# Optional AI integration
OPENAI_API_KEY=your-openai-api-key
OPENAI_PROJECT_ID=your-openai-project-id
OPENAI_PLAYBOOK_MODEL=gpt-4.1-mini

# Optional Stream Video integration
NEXT_PUBLIC_STREAM_VIDEO_API_KEY=your-stream-video-api-key
STREAM_VIDEO_API_SECRET=your-stream-video-api-secret

# Optional monitoring
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn